# ============================================================
#  LZD/SHP -> LINE Order Notification — environment variables
#  Copy this file to ".env" and fill in your real values.
# ============================================================

# ---- Server ----
# On Railway, PORT is injected automatically — leave this for local dev only.
PORT=3000
# Public HTTPS URL of this service. REQUIRED for Shopee signature verification
# (must exactly match the callback URL). On Railway use your generated domain,
# e.g. https://your-app.up.railway.app
PUBLIC_BASE_URL=https://your-domain.example.com
# Where the dedup state is stored. On Railway, attach a volume and set this to
# its mount path (e.g. /data) so notifications aren't re-sent after a redeploy.
DATA_DIR=

# ============================================================
#  LINE Messaging API (the bot that posts to your Packaging group)
# ============================================================
# From LINE Developers Console > your Messaging API channel > "Messaging API" tab.
LINE_CHANNEL_ACCESS_TOKEN=
# From the "Basic settings" tab — used to verify LINE webhook signatures.
LINE_CHANNEL_SECRET=
# The target the bot pushes to. A group ID (starts with "C"), room ID ("R"),
# or a user ID ("U"). See README for how to capture this from a webhook event.
LINE_TARGET_ID=

# ============================================================
#  Lazada Open Platform
#  https://open.lazada.com  (App Console > your app)
# ============================================================
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
# OAuth access token for the connected seller account.
LAZADA_ACCESS_TOKEN=
# Regional gateway. One of:
#   Singapore  https://api.lazada.sg/rest
#   Malaysia   https://api.lazada.com.my/rest
#   Thailand   https://api.lazada.co.th/rest
#   Vietnam    https://api.lazada.vn/rest
#   Philippines https://api.lazada.com.ph/rest
#   Indonesia  https://api.lazada.co.id/rest
LAZADA_API_BASE=https://api.lazada.co.th/rest

# ============================================================
#  Shopee Open Platform
#  https://open.shopee.com  (Console > your app)
# ============================================================
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=
# Live (production) host. Sandbox is https://partner.test-stable.shopeemobile.com
SHOPEE_API_BASE=https://partner.shopeemobile.com

# ============================================================
#  Polling fallback (used if you cannot expose a public webhook)
# ============================================================
# Set to "true" to enable the built-in poller (npm run poll).
ENABLE_POLLING=false
# How often to poll, in seconds.
POLL_INTERVAL_SECONDS=120
